# Rust
chain/target/
**/*.rs.bk

# Node
node_modules/
.pnpm-store/

# Next.js
explorer/.next/
explorer/out/

# Env & secrets — never commit keys
.env
.env.*
!.env.example
keys/
*.keypair.json
sequencer*.json

# Real node config (holds RPC API keys + key paths) and live genesis.
# Only the *.example.toml templates are committed.
config/node.toml
config/genesis.toml
config/secrets.env
config/*.local.toml
# Per-network live config (testnet/, mainnet/) — only the templates above
# (config/<net>/*.example.toml) are committed.
config/*/node.toml
config/*/genesis.toml
config/*/secrets.env
config/*/alert-webhook.txt

# Runtime data
data/
*.redb
backups/
test-ledger/

# Circuit artifacts (large, regenerated by scripts)
circuits/build/
circuits/ptau/
*.zkey
*.wtns
# Proving keys are large/regenerable; verifying keys (artifacts/*.vk.bin) are
# public params and ARE committed.

# Anchor
programs/target/
programs/.anchor/
programs/test-ledger/

# Misc
.DS_Store
*.log
