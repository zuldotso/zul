# Zul mainnet health check (oneshot, driven by zul-health.timer).
# Install: sudo cp deploy/zul-health.{service,timer} /etc/systemd/system/
#          sudo systemctl daemon-reload && sudo systemctl enable --now zul-health.timer
[Unit]
Description=Zul mainnet health check
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
ExecStart=/home/ubuntu/zul/scripts/zul-health.sh
